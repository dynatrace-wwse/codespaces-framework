# =============================================================================
# Enablement Ops Server — Environment Variables
# =============================================================================
# Copy to ~/.env and fill in the values.
# =============================================================================

# ── GitHub ───────────────────────────────────────────────────────────────────
# Webhook secret (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=

# ── GitHub OAuth (dashboard SSO via oauth2-proxy) ────────────────────────────
# Create an OAuth App at:
#   https://github.com/organizations/<org>/settings/applications/new
# Authorization callback URL:
#   https://<your-domain>/oauth2/callback
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_GITHUB_ORG=dynatrace-wwse
# Cookie secret — generate with: openssl rand -base64 32 | tr -- '+/' '-_'
OAUTH2_COOKIE_SECRET=

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Dynatrace ────────────────────────────────────────────────────────────────
# COE tenant URL (apps URL format)
DT_ENVIRONMENT=https://geu80787.apps.dynatrace.com

# Operator token (scope: activeGateTokenManagement.create, entities.read, settings.write,
# settings.read, DataExport, InstallerDownload)
DT_OPERATOR_TOKEN=dt0c01.

# Ingest token (scope: metrics.ingest, logs.ingest, openTelemetryTrace.ingest)
DT_INGEST_TOKEN=dt0c01.

# API token for MCP server and dtctl (scope: Read entities, Read settings, Read metrics,
# Read logs, Read events, Read problems, Read SLOs, Write settings)
DT_API_TOKEN=dt0s16.

# ── Codespaces Tracker ──────────────────────────────────────────────────────
ENDPOINT_CODESPACES_TRACKER=https://codespaces-tracker.whydevslovedynatrace.com/api/receive
CODESPACES_TRACKER_TOKEN=aWxvdmVkeW5hdHJhY2U=

# ── Server Configuration ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
OPS_HOST=0.0.0.0
OPS_PORT=8443

# Max parallel integration test workers (each needs ~4GB RAM + Kind cluster)
MAX_PARALLEL_WORKERS=6

# Max parallel Claude Code agent sessions
MAX_PARALLEL_AGENTS=2

# ── Multi-Arch (for remote worker nodes only) ──────────────────────────────
# MASTER_REDIS_URL=redis://<master-private-ip>:6379/0
# MASTER_REDIS_PASSWORD=<from master's .env.generated>
# WORKER_ARCH=amd64
# WORKER_CAPACITY=6
