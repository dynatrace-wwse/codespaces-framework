        "type": "data",
        "query": "fetch bizevents, from:now()-7d\n| filter event.provider == \"dynatrace-wwse.github.io\"\n| makeTimeseries views = count(), interval: 1d",
        "visualization": "areaChart",
        "visualizationSettings": {
          "coloring": {
