        "query": "fetch bizevents, from:now()-7d\n| filter event.provider == \"dynatrace-wwse.github.io\"\n| filter isNotNull(geo.country.name)\n| summarize countries = countDistinct(geo.country.name)",
        "visualization": "singleValue",
